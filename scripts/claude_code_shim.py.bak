#!/usr/bin/env python3
"""
OpenAI-compatible HTTP shim over Claude Code CLI.

Exposes POST /v1/chat/completions that shells out to `claude --print --output-format json`.
This bypasses Anthropic's OAuth-token API restriction because claude CLI uses its own
internal auth path which is always allowed for subscription OAuth tokens.

Why this exists: Anthropic blocks OAuth tokens on the direct Messages API for third-party
tools (since Feb 2026), but the claude CLI itself is always allowed. Wrapping it gives
us a "free" (subscription-covered) Anthropic endpoint.

Limitations:
- No streaming (claude --print is batch-only)
- No tool calling (agent loop is Claude Code's own, not OpenAI tool-call format)
- Startup latency ~1-2s per request (claude CLI spin-up)
- Single-message format only (chat history flattened into a single prompt)

Usage:
  uv run python claude_code_shim.py --port 8090
"""
import argparse
import json
import subprocess
import time
import uuid
from http.server import BaseHTTPRequestHandler, HTTPServer
from socketserver import ThreadingMixIn


CLAUDE_BIN = "claude"
DEFAULT_MODEL = "claude-sonnet-4-6"


def flatten_messages(messages):
    """Flatten OpenAI chat messages into a single prompt for claude --print."""
    lines = []
    system_parts = []
    for m in messages:
        role = m.get("role", "user")
        content = m.get("content", "")
        if isinstance(content, list):
            # OpenAI multimodal — extract text parts only
            content = "\n".join(
                part.get("text", "") for part in content if part.get("type") == "text"
            )
        if role == "system":
            system_parts.append(content)
        elif role == "user":
            lines.append(f"User: {content}")
        elif role == "assistant":
            lines.append(f"Assistant: {content}")
    prompt = "\n\n".join(lines)
    system_prompt = "\n\n".join(system_parts) if system_parts else None
    return prompt, system_prompt


def call_claude(prompt, system_prompt=None, model=None, max_tokens=None):
    cmd = [
        CLAUDE_BIN,
        "--print",
        "--permission-mode", "bypassPermissions",
        "--output-format", "json",
        "--no-session-persistence",
    ]
    if model and model != DEFAULT_MODEL:
        cmd.extend(["--model", model])
    if system_prompt:
        cmd.extend(["--append-system-prompt", system_prompt])
    cmd.append(prompt)

    try:
        result = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            timeout=300,
        )
    except subprocess.TimeoutExpired:
        return {"error": "claude CLI timeout after 300s"}
    except FileNotFoundError:
        return {"error": f"claude binary not found at {CLAUDE_BIN}"}

    if result.returncode != 0:
        return {"error": f"claude exit {result.returncode}: {result.stderr[:500]}"}

    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError as e:
        return {"error": f"json parse: {e} | raw: {result.stdout[:500]}"}

    if data.get("is_error"):
        return {"error": data.get("result", "unknown claude error")}

    return data


def to_openai_response(claude_result, model):
    """Convert claude JSON result to OpenAI chat.completions format."""
    text = claude_result.get("result", "")
    usage = claude_result.get("usage", {})
    return {
        "id": f"chatcmpl-{uuid.uuid4().hex[:24]}",
        "object": "chat.completion",
        "created": int(time.time()),
        "model": model,
        "choices": [
            {
                "index": 0,
                "message": {
                    "role": "assistant",
                    "content": text,
                },
                "finish_reason": "stop",
            }
        ],
        "usage": {
            "prompt_tokens": usage.get("input_tokens", 0) + usage.get("cache_read_input_tokens", 0),
            "completion_tokens": usage.get("output_tokens", 0),
            "total_tokens": (
                usage.get("input_tokens", 0)
                + usage.get("cache_read_input_tokens", 0)
                + usage.get("output_tokens", 0)
            ),
        },
    }


class Handler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        # Quiet logs
        pass

    def _json(self, code, body):
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        data = json.dumps(body).encode()
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        if self.path == "/health":
            return self._json(200, {"status": "ok", "backend": "claude-code-cli"})
        if self.path == "/v1/models":
            return self._json(200, {
                "object": "list",
                "data": [
                    {"id": "claude-sonnet-4-6", "object": "model", "owned_by": "anthropic"},
                    {"id": "claude-opus-4-6", "object": "model", "owned_by": "anthropic"},
                    {"id": "claude-haiku-4-5", "object": "model", "owned_by": "anthropic"},
                ],
            })
        return self._json(404, {"error": "not found"})

    def do_POST(self):
        if self.path != "/v1/chat/completions":
            return self._json(404, {"error": "not found"})

        length = int(self.headers.get("Content-Length", 0))
        try:
            body = json.loads(self.rfile.read(length) or b"{}")
        except json.JSONDecodeError:
            return self._json(400, {"error": "invalid json"})

        messages = body.get("messages", [])
        model = body.get("model", DEFAULT_MODEL)
        # Strip any provider prefix if present
        if "/" in model:
            model = model.split("/")[-1]

        prompt, system_prompt = flatten_messages(messages)
        if not prompt:
            return self._json(400, {"error": "no user message"})

        result = call_claude(prompt, system_prompt=system_prompt, model=model)
        if "error" in result:
            return self._json(500, {"error": {"message": result["error"], "type": "claude_cli_error"}})

        return self._json(200, to_openai_response(result, model))


class ThreadingHTTPServer(ThreadingMixIn, HTTPServer):
    daemon_threads = True


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8090)
    args = parser.parse_args()

    server = ThreadingHTTPServer((args.host, args.port), Handler)
    print(f"Claude Code shim listening on http://{args.host}:{args.port}")
    print(f"  GET  /health")
    print(f"  GET  /v1/models")
    print(f"  POST /v1/chat/completions")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down")
        server.shutdown()


if __name__ == "__main__":
    main()
