\appendices
\section{Formal Properties and Proofs}
\label{sec:proofs}

We now provide formal proofs for key properties of \evoclaw{}'s design.

\subsection{Memory Boundedness}

\begin{theorem}[Context Boundedness]
For any \evoclaw{} agent with configuration parameters $(H, W, T)$ where $H$ is hot memory limit, $W$ is warm memory limit, and $T$ is tree index limit, the context tokens per turn is bounded by:
\begin{equation}
\text{Context} \leq H + W \cdot k + T
\end{equation}
where $k$ is the maximum number of warm entries retrieved per query (default $k=5$).
\end{theorem}

\begin{proof}
The context for each turn consists of:
\begin{enumerate}
    \item Hot memory: always loaded, size $\leq H$
    \item Tree index: always loaded, size $\leq T$
    \item Retrieved warm entries: at most $k$ entries, each bounded by warm entry size limit
    \item Current conversation: bounded by LLM context window management
\end{enumerate}
Since each component has a fixed upper bound, their sum is bounded. The bound is independent of conversation history length, cold memory size, or operation duration.
\end{proof}

\begin{corollary}[Infinite-Time Operation]
An \evoclaw{} agent can operate for unbounded time without context growth.
\end{corollary}

\subsection{Evolution Convergence}

\begin{theorem}[Evolution Convergence]
Let $g_t$ be the genome at evolution iteration $t$, and let $\fitnessfn^*$ be the maximum fitness achievable in genome space $\genomespace$. Under the following assumptions:
\begin{enumerate}
    \item $\fitnessfn: \genomespace \to [0, 1]$ is continuous
    \item Mutation operator $\mutation$ has positive probability of reaching any $g' \in \genomespace$ from any $g \in \genomespace$ in finite steps
    \item Selection retains $g_t$ if $\fitnessfn(g_{t+1}) < \fitnessfn(g_t) - \delta$ for some $\delta > 0$
\end{enumerate}
Then $\lim_{t \to \infty} \mathbb{E}[\fitnessfn(g_t)] = \fitnessfn^*$.
\end{theorem}

\begin{proof}[Proof sketch]
The evolution process defines a Markov chain over $\genomespace$. Assumption 2 ensures the chain is irreducible. The selection criterion (Assumption 3) ensures that fitness is non-decreasing in expectation. By the monotone convergence theorem, the sequence $\mathbb{E}[\fitnessfn(g_t)]$ converges to its supremum, which equals $\fitnessfn^*$ by irreducibility.
\end{proof}

\subsection{Router Optimality}

\begin{theorem}[Routing Cost Optimality]
Let $\mathcal{M} = \{m_1, \ldots, m_n\}$ be the set of available models with costs $c_1 < c_2 < \ldots < c_n$ and quality thresholds $q_1 < q_2 < \ldots < q_n$. For a task requiring quality level $q$, the intelligent router selects model $m_i$ where $i = \min\{j : q_j \geq q\}$. This selection minimizes cost among models meeting quality requirement.
\end{theorem}

\begin{proof}
By construction, $m_i$ is the cheapest model with quality $\geq q$. Any model $m_j$ with $j < i$ has $q_j < q$ and thus fails quality requirement. Any model $m_j$ with $j > i$ has $c_j > c_i$ and thus higher cost. Therefore $m_i$ is cost-optimal.
\end{proof}

\subsection{Safety Invariant Preservation}

\begin{theorem}[Constraint Preservation Under Evolution]
Let $C$ be the constraints section of genome $g$, defining blocked actions $B$ and safety bounds $S$. For any mutation operator $\mutation$ in \evoclaw{}:
\begin{equation}
\forall g, g' : g' = \mutation(g) \implies C(g') = C(g)
\end{equation}
That is, mutations preserve safety constraints.
\end{theorem}

\begin{proof}
By implementation, the mutation operators in \evoclaw{} (parameter perturbation, skill toggle, crossover) operate only on the Skills and Behavior sections of the genome. The Constraints section is marked as immutable in the genome schema. The validation algorithm (Algorithm~\ref{alg:validation}) rejects any genome where constraints are modified from the original.
\end{proof}

\begin{corollary}[Safety Under Evolution]
An agent that satisfies safety constraints at deployment continues to satisfy them after any number of evolution iterations.
\end{corollary}




