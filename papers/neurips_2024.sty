% neurips_2024.sty - Minimal NeurIPS 2024 style for arXiv preprints
% Based on the official NeurIPS style

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2024}[2024/01/01 NeurIPS 2024 Style (minimal)]

\newif\if@preprint\@preprinttrue
\newif\if@final\@finalfalse
\newif\if@nonatbib\@nonatbibfalse

\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{final}{\@finaltrue}
\DeclareOption{nonatbib}{\@nonatbibtrue}
\ProcessOptions\relax

% Page geometry
\RequirePackage[
  letterpaper,
  top=1in,
  bottom=1in,
  left=1.5in,
  right=1.5in
]{geometry}

% Typography - microtype with safe options
\RequirePackage[expansion=false]{microtype}

% Set up title
\def\@maketitle{%
  \newpage
  \null
  \vskip 2em%
  \begin{center}%
    {\LARGE \@title \par}%
    \vskip 1.5em%
    {\large
      \lineskip .5em%
      \begin{tabular}[t]{c}%
        \@author
      \end{tabular}\par}%
    \vskip 1em%
    \if@preprint
      {\normalsize Preprint. Under review.}
    \fi
  \end{center}%
  \par
  \vskip 1.5em}

% Author separator
\newcommand{\And}{%
  \end{tabular}%
  \hfill%
  \begin{tabular}[t]{c}%
}

\endinput
