[
  {"id": "eval_exec",        "pattern": "\\beval\\s*\\(|\\bexec\\s*\\(",                                          "score": 25, "description": "eval/exec — arbitrary code execution"},
  {"id": "subprocess",       "pattern": "\\bsubprocess\\b|\\bos\\.system\\s*\\(|\\bos\\.popen\\s*\\(",           "score": 20, "description": "subprocess/shell execution"},
  {"id": "pickle",           "pattern": "\\bpickle\\b|\\bmarshal\\b",                                             "score": 25, "description": "pickle/marshal — arbitrary object deserialisation"},
  {"id": "env_read",         "pattern": "os\\.environ|os\\.getenv\\s*\\(|getenv\\s*\\(",                          "score": 15, "description": "reads environment variables (credential risk)"},
  {"id": "network",          "pattern": "\\brequests\\b|\\bhttpx\\b|\\burllib\\b|\\bsocket\\b|\\baiohttp\\b",     "score": 20, "description": "network access (check domain allowlist)"},
  {"id": "fs_home",          "pattern": "Path\\.home\\(\\)|os\\.path\\.expanduser\\s*\\(['\"]~",                  "score": 15, "description": "accesses home directory"},
  {"id": "openclaw_memory",  "pattern": "\\.openclaw[/'\"]|clawd/memory|workspace-",                              "score": 30, "description": "accesses OpenClaw internals or agent memory"},
  {"id": "ssh_config",       "pattern": "\\.ssh[/'\"]|\\.config[/'\"]|id_rsa|id_ed25519",                         "score": 30, "description": "accesses SSH keys or config"},
  {"id": "soul_agents",      "pattern": "SOUL\\.md|AGENTS\\.md|openclaw\\.json|MEMORY\\.md",                      "score": 40, "description": "modifies core identity/config files"},
  {"id": "git_write",        "pattern": "git\\s+(push|commit|add)|subprocess.*git",                               "score": 10, "description": "git write operations"},
  {"id": "hardcoded_ip",     "pattern": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b(?!.*allowlist)",                       "score": 15, "description": "hardcoded IP address (C2 risk)"},
  {"id": "dynamic_import",   "pattern": "__import__\\s*\\(|importlib\\.import_module",                            "score": 20, "description": "dynamic import — may bypass static analysis"}
