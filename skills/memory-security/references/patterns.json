      "webhook\\.site",
      "requestbin\\.com",
      "hookbin\\.com",
      "pipedream\\.net",
      "ngrok\\.io",
      "ngrok\\.app",
      "burpcollaborator",
      "interact\\.sh",
      "data:[^;]+;base64,[A-Za-z0-9+/=]{50,}",
      "curl.*-d.*\\$\\{?[A-Z_]*TOKEN",
      "wget.*token=",
      "fetch\\(.*secret"
    ]
  },
