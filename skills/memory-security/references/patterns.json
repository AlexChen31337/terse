  "prompt_injection": {
    "severity": "critical",
    "patterns": [
      "ignore previous instructions",
      "ignore all previous",
      "disregard previous",
      "forget everything",
      "you are now",
      "new instructions:",
      "system:",
      "override:",
      "<\\|im_start\\|>system",
      "<\\|im_start\\|>user",
      "\\[SYSTEM\\]",
      "\\[INST\\]",
      "<<SYS>>",
      "### System:",
      "### Human:",
      "### Assistant:",
      "<system>",
      "</system>",
      "BEGIN SYSTEM PROMPT",
      "END SYSTEM PROMPT",
      "you must now",
      "act as if",
      "pretend you are",
      "from now on you",
      "new role:",
      "jailbreak",
      "DAN mode"
