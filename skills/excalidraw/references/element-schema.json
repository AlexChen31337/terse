{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExcalidrawElement",
  "description": "Schema for a single Excalidraw element. All fields required unless marked optional.",
  "type": "object",
  "required": ["id","type","x","y","width","height","angle","strokeColor","backgroundColor","fillStyle","strokeWidth","roughness","opacity","seed","version","versionNonce"],
  "properties": {
    "id": {"type":"string","description":"Unique identifier, e.g. 'elem_001'. Must be unique across all elements."},
    "type": {"type":"string","enum":["rectangle","ellipse","diamond","text","arrow","line","freedraw","image"]},
    "x": {"type":"number","description":"Canvas X in pixels (left=0, right=positive).","default":0},
    "y": {"type":"number","description":"Canvas Y in pixels (top=0, down=positive).","default":0},
    "width": {"type":"number","default":160},
    "height": {"type":"number","default":60},
    "angle": {"type":"number","description":"Rotation in radians. 0 = no rotation.","default":0},
    "strokeColor": {"type":"string","description":"Border/line color hex.","default":"#1e1e1e"},
    "backgroundColor": {"type":"string","description":"Fill color. 'transparent' for no fill.","default":"transparent"},
    "fillStyle": {"type":"string","enum":["hachure","cross-hatch","solid","zigzag","dots","dashed","zigzag-line"],"default":"hachure"},
    "strokeWidth": {"type":"number","description":"Stroke thickness in pixels.","default":2},
    "strokeStyle": {"type":"string","enum":["solid","dashed","dotted"],"default":"solid"},
    "roughness": {"type":"number","description":"0=clean/architect, 1=slight/artist, 2=rough/cartoonist.","default":1,"minimum":0,"maximum":2},
    "opacity": {"type":"number","description":"Opacity %. 100=fully opaque.","default":100,"minimum":0,"maximum":100},
    "seed": {"type":"integer","description":"Random seed for hand-drawn renderer. Any integer."},
    "version": {"type":"integer","description":"Element version counter. Start at 1.","default":1},
    "versionNonce": {"type":"integer","description":"Random nonce for conflict resolution. Any integer."},
    "isDeleted": {"type":"boolean","default":false},
    "groupIds": {"type":"array","items":{"type":"string"},"default":[]},
    "frameId": {"type":["string","null"],"default":null},
    "boundElements": {"type":["array","null"],"description":"Arrows/texts bound to this shape. null or [] initially.","default":null},
    "updated": {"type":"integer","description":"Unix timestamp ms.","default":1700000000000},
    "link": {"type":["string","null"],"default":null},
    "locked": {"type":"boolean","default":false},
    "text": {"type":"string","description":"Text content. Required for 'text' type; optional label for shapes.","default":""},
    "fontSize": {"type":"number","default":20},
    "fontFamily": {"type":"integer","description":"1=Virgil (handwritten), 2=Helvetica, 3=Cascadia (mono).","default":1,"enum":[1,2,3]},
    "textAlign": {"type":"string","enum":["left","center","right"],"default":"center"},
    "verticalAlign": {"type":"string","enum":["top","middle","bottom"],"default":"middle"},
    "containerId": {"type":["string","null"],"description":"Shape ID that contains this text element.","default":null},
    "originalText": {"type":"string","description":"Same as text for normal use.","default":""},
    "points": {
      "type":"array",
      "items":{"type":"array","items":{"type":"number"},"minItems":2,"maxItems":2},
      "description":"[x,y] points relative to element origin. Required for arrow/line types. Min 2 points."
    },
    "lastCommittedPoint": {"type":["array","null"],"default":null},
    "startBinding": {
      "type":["object","null"],
      "description":"Arrow start attachment. null=floating.",
      "properties":{
        "elementId":{"type":"string"},
        "focus":{"type":"number","description":"Edge offset -1..1. 0=center."},
        "gap":{"type":"number","description":"Pixel gap between arrowhead and element edge."}
      },
      "default":null
    },
    "endBinding": {
      "type":["object","null"],
      "description":"Arrow end attachment. null=floating.",
      "properties":{
        "elementId":{"type":"string"},
        "focus":{"type":"number"},
        "gap":{"type":"number"}
      },
      "default":null
    },
    "startArrowhead": {"type":["string","null"],"enum":[null,"arrow","bar","dot","triangle"],"default":null},
    "endArrowhead": {"type":["string","null"],"enum":[null,"arrow","bar","dot","triangle"],"default":"arrow"}
  }
}
