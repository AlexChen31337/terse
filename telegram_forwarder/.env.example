# Telegram Bot Configuration
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (pre-configured)
OWNER_ID=2069029798

# Channels to forward messages FROM
# Multiple channels separated by commas, no spaces
# Channel IDs are negative numbers (e.g., -1001234567890)
# Use channel_id_helper.py to find channel IDs
CHANNELS_TO_FORWARD=-1001234567890,-1009876543210
