# ── Google Drive ─────────────────────────────────────────────────────────────
# Path to a service account JSON *or* an OAuth 2.0 client JSON downloaded
# from https://console.cloud.google.com/apis/credentials
# Service accounts are recommended for server/CI use; OAuth for local dev.
GDRIVE_CREDENTIALS_FILE=credentials.json

# Where to cache the OAuth token between runs (user auth flow only).
# The file is created automatically on first login; treat it like a password.
GDRIVE_TOKEN_FILE=token.json

# Drive folder ID to upload into (copy from the URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID>)
# Leave empty to upload to the account root.
GDRIVE_FOLDER_ID=

# ── Storage ───────────────────────────────────────────────────────────────────
# Where generated images are saved locally before (optional) upload.
OUTPUT_DIR=./output

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
